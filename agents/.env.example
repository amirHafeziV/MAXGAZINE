# Anthropic API key — required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Production site origin used for canonical/OG/hreflang URLs and sitemap.
SITE_ORIGIN=https://maxgazine.com

# Optional: comma-separated RSS feeds the Scout agent reads.
# Defaults to a built-in crypto/forex feed list if unset.
NEWS_FEEDS=

# Optional model overrides (sensible defaults are in src/config.ts).
MODEL_WRITER=claude-opus-4-7
MODEL_FAST=claude-haiku-4-5-20251001
