# Clean URLs for coin pages: /bitcoin-btc -> /bitcoin-btc.html (no redirect,
# canonical stays extension-less). Only applies to single-segment paths that
# aren't real files/directories (so /admin, /assets, /en/... etc. are untouched).
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Canonical home: the homepage is always served at "/" — never /index.html or
# /index. Redirect those explicit requests (e.g. a logo link or a bookmark) to
# the bare root so the address bar stays clean. Matches the literal request line
# so the internal DirectoryIndex mapping of "/" -> index.html never loops.
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^index(\.html)?$ / [R=301,L]

# Coin pages moved from the root (/bitcoin-btc[.html], client-switched language)
# to per-language URLs (/en/bitcoin-btc.html etc.) for clean multilingual SEO.
# 301 the old root URLs to the English page so indexed links keep their equity.
# This block is regenerated by build/build.ts (keep the BEGIN/END markers).
# BEGIN coin-redirects
RewriteRule ^(bitcoin-btc|ethereum-eth|bnb|tether-usdt|xrp|solana-sol|tron-trx|dogecoin-doge|hyperliquid-hype|leo-token-leo|zcash-zec|cardano-ada|monero-xmr|stellar-xlm|canton-cc|whitebit-coin-wbt|chainlink-link|toncoin-ton|bitcoin-cash-bch|memecore-m|hedera-hbar|litecoin-ltc|sui|shiba-inu-shib|avalanche-avax|cronos-cro|near-protocol-near|bittensor-tao|world-liberty-financial-wlfi|ondo|mantle-mnt|worldcoin-wld|aster|polkadot-dot|uniswap-uni|okb|htx-dao-htx|pi-network-pi|internet-computer-icp|sky|morpho|bitget-token-bgb|pepe|ethereum-classic-etc|aave|cosmos-hub-atom|quant-qnt|kucoin-kcs|render|kaspa-kas|dexe|pol-ex-matic-pol|nexo|ethena-ena|algorand-algo|venice-token-vvv)(\.html)?$ /en/$1.html [R=301,L]
# END coin-redirects

# Clean URLs for remaining single-segment root pages: /about -> /about.html.
# Only applies to paths that aren't real files/directories (so /admin, /assets,
# /en/... etc. are untouched). Coin slugs are intercepted by the 301 block above.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([a-z0-9-]+)$ $1.html [L]

# Cache policy. The site ships no content-hashed filenames, so HTML, the feed/
# data JSON, and app.js/css must always be revalidated — otherwise browsers
# heuristically cache them and newly published articles appear "missing" until
# the visitor manually clears their cache. "no-cache" still allows efficient
# 304s (download only when actually changed). Images/fonts are immutable enough
# to cache for a week.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|json|js|css|xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
