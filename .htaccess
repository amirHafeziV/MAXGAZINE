# Clean URLs for coin pages: /bitcoin-btc -> /bitcoin-btc.html (no redirect,
# canonical stays extension-less). Only applies to single-segment paths that
# aren't real files/directories (so /admin, /assets, /en/... etc. are untouched).
RewriteEngine On

# Canonical home: the homepage is always served at "/" — never /index.html or
# /index. Redirect those explicit requests (e.g. a logo link or a bookmark) to
# the bare root so the address bar stays clean. Matches the literal request line
# so the internal DirectoryIndex mapping of "/" -> index.html never loops.
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^index(\.html)?$ / [R=301,L]

# Clean URLs for coin pages: /bitcoin-btc -> /bitcoin-btc.html (no redirect,
# canonical stays extension-less). Only applies to single-segment paths that
# aren't real files/directories (so /admin, /assets, /en/... etc. are untouched).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([a-z0-9-]+)$ $1.html [L]

# Cache policy. The site ships no content-hashed filenames, so HTML, the feed/
# data JSON, and app.js/css must always be revalidated — otherwise browsers
# heuristically cache them and newly published articles appear "missing" until
# the visitor manually clears their cache. "no-cache" still allows efficient
# 304s (download only when actually changed). Images/fonts are immutable enough
# to cache for a week.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|json|js|css|xml)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>
