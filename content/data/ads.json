      "code": "<!DOCTYPE html>\n<html lang=\"fa\" dir=\"rtl\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Maxgazine Forecast — FA</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href='https://fonts.googleapis.com/css2?family=Estedad:wght@400;500;600;700;900&family=Fraunces:wght@600;700;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap' rel='stylesheet'>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { background: #faf9f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; }\n\n    @keyframes ken{0%{transform:scale(1.06) translate(0,0)}50%{transform:scale(1.13) translate(-2%,-1.5%)}100%{transform:scale(1.06) translate(0,0)}}\n    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.65)}}\n    @keyframes pastDraw{0%{stroke-dashoffset:400;opacity:0}4%{stroke-dashoffset:400;opacity:1;animation-timing-function:cubic-bezier(.2,.7,.2,1)}34%{stroke-dashoffset:0;opacity:1}88%{stroke-dashoffset:0;opacity:1}96%{stroke-dashoffset:0;opacity:0}100%{stroke-dashoffset:400;opacity:0}}\n    @keyframes areaIn{0%{opacity:0}12%{opacity:0}34%{opacity:.14}88%{opacity:.14}96%{opacity:0}100%{opacity:0}}\n    @keyframes nowFade{0%{opacity:0}30%{opacity:0}40%{opacity:1}88%{opacity:1}96%{opacity:0}100%{opacity:0}}\n    @keyframes fcFade{0%{opacity:0}42%{opacity:0}58%{opacity:1}88%{opacity:1}96%{opacity:0}100%{opacity:0}}\n    @keyframes fcMarch{to{stroke-dashoffset:-17}}\n    @keyframes popTarget{0%{opacity:0;r:0px}56%{opacity:0;r:0px}61%{opacity:1;r:9px;animation-timing-function:cubic-bezier(.2,.7,.2,1)}64%{r:7px}88%{opacity:1;r:7px}96%{opacity:0;r:7px}100%{opacity:0;r:0px}}\n    @keyframes popActual{0%{opacity:0;r:0px}63%{opacity:0;r:0px}68%{opacity:1;r:7px}71%{r:5px}88%{opacity:1;r:5px}96%{opacity:0;r:5px}