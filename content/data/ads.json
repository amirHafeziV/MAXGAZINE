      "code": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }\n  html, body { width: 1200px; height: 400px; overflow: hidden; background: #F7F2E6; }\n  #root { position: absolute; inset: 0; }\n</style>\n</head>\n<body>\n<div id=\"root\"></div>\n\n<script crossorigin src=\"https://unpkg.com/react@18.3.1/umd/react.production.min.js\"></script>\n<script crossorigin src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.26.4/babel.min.js\"></script>\n\n<script type=\"text/babel\" data-presets=\"react\">\n// ── Easing ──────────────────────────────────────────────────────────────────\nconst Easing = {\n  linear: t => t,\n  easeInQuad:    t => t * t,\n  easeOutQuad:   t => t * (2 - t),\n  easeInCubic:   t => t * t * t,\n  easeOutCubic:  t => (--t) * t * t + 1,\n  easeInOutCubic:t => t < 0.5 ? 4*t*t*t : (t-1)*(2*t-2)*(2*t-2)+1,\n  easeOutExpo:   t => t === 1 ? 1 : 1 - Math.pow(2, -10 * t),\n  easeOutBack:   t => { const c1=1.70158, c3=c1+1; return 1+c3*Math.pow(t-1,3)+c1*Math.pow(t-1,2); },\n  easeInBack:    t => { const c1=1.70158, c3=c1+1; return c3*t*t*t - c1*t*t; },\n  easeInCubicFn: t => t * t * t,\n  easeOutQuad:   t => t * (2 - t),\n  easeInQuad2:   t => t * t,\n};\n\nconst clamp = (v, min, max) => Math.max(min, Math.min(max, v));\n\nfunction animate({ from=0, to=1, start=0, end=1, ease=Easing.easeOutCubic }) {\n  return t => {\n    if (t <= start) return from;\n    if (t >= end) return to;\n    return from + (to - from) * ease((t - start) / (end - start));\n  };\n}\n\n// ── Timeline context ─────────────────────────────────────────────────────────\nconst TimelineContext = React.createContext({ time: 0, duration: 16 });\nconst useTime = () => React.useContext(TimelineContext).time;\n\n// ── Stage (no player bar) ────────────────────────────────────────────────────\nfunction Stage({ width=1200, height=400, duration=16, background='#F7F2E6', loop=true, autoplay=true, children }) {\n  const [time, setTime] = React.useState(0);\n  const [playing] = React.useState(autoplay);\n  const rafRef = React.useRef(null);\n  const lastTsRef = React.useRef(null);\n\n  React.useEffect(() => {\n    if (!playing) return;\n    const step = ts => {\n      if (lastTsRef.current == null) lastTsRef.current = ts;\n      const dt = (ts - lastTsRef.current) / 1000;\n      lastTsRef.current = ts;\n      setTime(t => {\n        let next = t + dt;\n        if (next >= duration) next = loop ? next % duration : duration;\n        return next;\n      });\n      rafRef.current = requestAnimationFrame(step);\n    };\n    rafRef.current = requestAnimationFrame(step);\n    return () => { cancelAnimationFrame(rafRef.current); lastTsRef.current = null; };\n  }, [playing, duration, loop]);\n\n  const ctx = React.useMemo(() => ({ time, duration }), [time, duration]);\n\n  return (\n    <div style={{ position:'absolute', inset:0, overflow:'hidden', background }}>\n      <TimelineContext.Provider value={ctx}>\n        {children}\n      </TimelineContext.Provider>\n    </div>\n  );\n}\n\n// ── Scene components ─────────────────────────────────────────────────────────\nconst C = {\n  bg:'#F7F2E6', ink:'#14201F', ink2:'#2C3A39',\n  muted:'#8A938E', muted2:'#B5B8B0',\n  green:'#4CAF7A', greenInk:'#0F3A24',\n  yellow:'#E5B73B', red:'#E76A3F',\n  card:'#FFFCF3',\n  line:'rgba(20,32,31,0.08)', line2:'rgba(20,32,31,0.14)',\n};\nconst f = 'Inter, system-ui, sans-serif';\n\nfunction SceneWrap({ idx, children }) {\n  const SDUR = 4, TR = 0.55;\n  const t = useTime();\n  const s0 = idx * SDUR, s1 = s0 + SDUR;\n  if (t < s0 || t >= s1) return null;\n  const lt = t - s0;\n  let op = 1, tx = 0;\n  if (lt < TR) {\n    const p = Easing.easeOutCubic(lt / TR);\n    op = p; tx = (1 - p) * 64;\n  } else if (lt > SDUR - TR) {\n    const p = Easing.easeInCubic((lt - (SDUR - TR)) / TR);\n    op = 1 - p; tx = -p * 44;\n  }\n  return (\n    <div style={{ position:'absolute', inset:0, opacity:op, transform:`translateX(${tx}px)`, willChange:'opacity,transform' }}>\n      {children}\n    </div>\n  );\n}\n\nfunction GridBg() {\n  return (\n    <div style={{\n      position:'absolute', inset:0,\n      backgroundColor: C.bg,\n      backgroundImage: [`linear-gradient(${C.line} 1px,transparent 1px)`, `linear-gradient(90deg,${C.line} 1px,transparent 1px)`].join(','),\n      backgroundSize: '80px 80px',\n    }} />\n  );\n}\n\nfunction Scene1() {\n  const t = useTime(), lt = t;\n  const a = (fr, to, s, en, ease) => animate({ from:fr, to, start:s, end:en, ease: ease||Easing.easeOutCubic })(lt);\n  const cards = [\n    { tag:'MARKETS',  cat:C.green,  title:'Bitcoin surges 12% as institutional demand rises', t0:0.65 },\n    { tag:'ANALYSIS', cat:C.yellow, title:'Fed signals rate pause — impact on crypto markets', t0:0.90 },\n    { tag:'DEFI',     cat:C.red,    title:'DeFi TVL hits $180B — record high since 2022',     t0:1.15 },\n  ];\n  return (\n    <>\n      <div style={{ position:'absolute', left:80, top:0, bottom:0, width:500, display:'flex', flexDirection:'column', justifyContent:'center' }}>\n        <div style={{ opacity:a(0,1,0.12,0.48), transform:`translateY(${a(10,0,0.12,0.48)}px)`, fontFamily:f, fontSize:15, fontWeight:700, letterSpacing:'0.14em', textTransform:'uppercase', color:C.green, marginBottom:14 }}>Market Intelligence Platform</div>\n        <div style={{ opacity:a(0,1,0.38,0.82,Easing.easeOutBack), transform:`translateY(${a(28,0,0.38,0.82)}px)`, fontFamily:f, fontSize:94, fontWeight:900, letterSpacing:'-0.04em', color:C.ink, lineHeight:0.91, marginBottom:22 }}>MAXGAZINE</div>\n        <div style={{ width:a(0,260,0.92,1.42), height:3, background:C.green, borderRadius:2, marginBottom:16 }} />\n        <div style={{ opacity:a(0,1,1.18,1.58), fontFamily:f, fontSize:21, fontWeight:500, color:C.muted, letterSpacing:'-0.01em', lineHeight:1.5 }}>The trusted source for traders worldwide</div>\n      </div>\n      <div style={{ position:'absolute', right:60, top:0, bottom:0, width:500, display:'flex', flexDirection:'column', justifyContent:'center', gap:10 }}>\n        {cards.map(({ tag, cat, title, t0 }) => (\n          <div key={tag} style={{ opacity:a(0,1,t0,t0+0.38), transform:`translateX(${a(52,0,t0,t0+0.38)}px)`, background:C.card, borderRadius:14, padding:'14px 18px', boxShadow:'0 1px 3px rgba(20,32,31,0.06),0 4px 14px rgba(20,32,31,0.05)', display:'flex', alignItems:'flex-start', gap:12 }}>\n            <div style={{ width:3, alignSelf:'stretch', background:cat, borderRadius:2, flexShrink:0, marginTop:1 }} />\n            <div>\n              <div style={{ fontFamily:f, fontSize:13, fontWeight:700, letterSpacing:'0.1em', textTransform:'uppercase', color:cat, marginBottom:6 }}>{tag}</div>\n              <div style={{ fontFamily:f, fontSize:17, fontWeight:600, color:C.ink, letterSpacing:'-0.01em', lineHeight:1.35 }}>{title}</div>\n            </div>\n          </div>\n        ))}\n      </div>\n    </>\n  );\n}\n\nfunction Scene2() {\n  const t = useTime(), lt = t - 4;\n  const a = (fr, to, s, en, ease) => animate({ from:fr, to, start:s, end:en, ease: ease||Easing.easeOutCubic })(lt);\n  const numProg = Easing.easeOutExpo(clamp((lt - 0.18) / 1.42, 0, 1));\n  const thousands = Math.round(numProg * 50);\n  const displayNum = thousands >= 50 ? '50K+' : (thousands > 0 ? thousands + 'K' : '0');\n  const bars = [{ h:68, d:0.38 },{ h:100, d:0.52 },{ h:132, d:0.66 },{ h:165, d:0.80 },{ h:200, d:0.94 }];\n  return (\n    <>\n      <div style={{ position:'absolute', left:80, top:0, bottom:0, width:460, display:'flex', flexDirection:'column', justifyContent:'center' }}>\n        <div style={{ opacity:a(0,1,0.08,0.38), fontFamily:f, fontSize:15, fontWeight:700, letterSpacing:'0.14em', textTransform:'uppercase', color:C.green, marginBottom:10 }}>Active Traders</div>\n        <div style={{ opacity:a(0,1,0.14,0.48), fontFamily:f, fontSize:128, fontWeight:900, letterSpacing:'-0.05em', color:C.ink, lineHeight:0.86, marginBottom:20, fontVariantNumeric:'tabular-nums' }}>{displayNum}</div>\n        <div style={{ width:a(0,60,0.82,1.18), height:2, background:C.green, borderRadius:1, marginBottom:14 }} />\n        <div style={{ opacity:a(0,1,0.98,1.38), fontFamily:f, fontSize:21, fontWeight:500, color:C.muted, letterSpacing:'-0.01em', lineHeight:1.55, whiteSpace:'pre-wrap' }}>{'Read Maxgazine daily\\nfor market intelligence'}</div>\n      </div>\n      <div style={{ position:'absolute', right:80, bottom:56, display:'flex', alignItems:'flex-end', gap:16 }}>\n        {bars.map(({ h, d }, i) => {\n          const bh = a(0, h, d, d + 0.52);\n          const isLast = i === bars.length - 1;\n          return (\n            <div key={i} style={{ position:'relative', width:52 }}>\n              {isLast && <div style={{ position:'absolute', bottom:bh+8, left:'50%', transform:'translateX(-50%)', fontFamily:f, fontSize:16, fontWeight:700, color:C.green, opacity:a(0,1,d+0.48,d+0.76), whiteSpace:'nowrap' }}>↑ 38%</div>}\n              <div style={{ width:'100%', height:bh, background:isLast ? C.green : `rgba(76,175,122,${0.14+i*0.1})`, borderRadius:'8px 8px 0 0' }} />\n            </div>\n          );\n        })}\n      </div>\n      <div style={{ position:'absolute', right:64, bottom:55, width:360, height:1, background:C.line2 }} />\n      <div style={{ position:'absolute', right:64, bottom:33, width:360, textAlign:'center', fontFamily:f, fontSize:13, fontWeight:600, letterSpacing:'0.1em', textTransform:'uppercase', color:C.muted2, opacity:a(0,1,1.38,1.72) }}>Daily Readership Growth</div>\n    </>\n  );\n}\n\nfunction Scene3() {\n  const t = useTime(), lt = t - 8;\n  const a = (fr, to, s, en, ease) => animate({ from:fr, to, start:s, end:en, ease: ease||Easing.easeOutCubic })(lt);\n  const NW=162, NH=92, n1x=98, n2x=519, n3x=940, ny=154, GAP=259;\n  const lnY = ny + NH / 2;\n\n  const mkParticle = (lx, startT, dur) => {\n    const px = a(lx, lx+GAP, startT, startT+dur);\n    const fi = Easing.easeOutQuad(clamp((lt-startT)/0.14, 0, 1));\n    const fo = 1 - Easing.easeInQuad(clamp((lt-(startT+dur-0.14))/0.14, 0, 1));\n    return <div key={`p${startT}`} style={{ position:'absolute', left:px-5, top:lnY-5, width:10, height:10, borderRadius:'50%', background:C.green, opacity:Math.min(fi,fo), boxShadow:'0 0 8px 3px rgba(76,175,122,0.35)' }} />;\n  };\n\n  const mkNode = (x, op, ty, dark, border, label, sub, lc, sc, icon) => (\n    <div style={{ position:'absolute', left:x, top:ny, width:NW, height:NH, opacity:op, transform:`translateY(${ty}px)`, background:dark?C.ink:C.card, borderRadius:18, border:border?`2px solid ${border}`:`1.5px solid ${C.line2}`, boxShadow:dark?'0 8px 32px rgba(20,32,31,0.22)':'0 2px 14px rgba(20,32,31,0.06)', display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center', gap:5 }}>\n      {icon}\n      <div style={{ fontFamily:f, fontSize:13, fontWeight:700, letterSpacing:'0.1em', textTransform:'uppercase', color:lc }}>{label}</div>\n      <div style={{ fontFamily:f, fontSize:12, fontWeight:500, color:sc||C.muted }}>{sub}</div>\n    </div>\n  );\n\n  return (\n    <>\n      <div style={{ position:'absolute', top:34, left:0, right:0, textAlign:'center', opacity:a(0,1,0.08,0.38), fontFamily:f, fontSize:15, fontWeight:700, letterSpacing:'0.14em', textTransform:'uppercase', color:C.green }}>How It Works</div>\n      {mkNode(n1x, a(0,1,0.18,0.58,Easing.easeOutBack), a(22,0,0.18,0.58), false, null, 'Your Brand', 'Advertiser', C.muted, null,\n        <svg width=\"30\" height=\"30\" viewBox=\"0 0 30 30\" fill=\"none\"><rect x=\"4\" y=\"11\" width=\"22\" height=\"15\" rx=\"3\" fill=\"rgba(20,32,31,0.10)\"/><rect x=\"10\" y=\"4\" width=\"10\" height=\"8\" rx=\"2\" fill=\"rgba(20,32,31,0.16)\"/><rect x=\"12\" y=\"17\" width=\"6\" height=\"9\" fill=\"rgba(20,32,31,0.07)\"/></svg>\n      )}\n      <div style={{ position:'absolute', left:n1x+NW, top:lnY-1, width:a(0,GAP,0.72,1.22), height:2, background:`linear-gradient(90deg,${C.green},rgba(76,175,122,0.25))`, borderRadius:1 }} />\n      {mkParticle(n1x+NW, 1.28, 0.58)}\n      {mkParticle(n1x+NW, 1.68, 0.52)}\n      {mkNode(n2x, a(0,1,1.10,1.50,Easing.easeOutBack), a(22,0,1.10,1.50), true, null, 'MAXGAZINE', 'Trusted Source', '#F7F2E6', C.green,\n        <div style={{ fontFamily:f, fontSize:36, fontWeight:900, letterSpacing:'-0.04em', color:'#F7F2E6', lineHeight:1, marginBottom:1 }}>M</div>\n      )}\n      <div style={{ position:'absolute', left:n2x+NW, top:lnY-1, width:a(0,GAP,1.62,2.12), height:2, background:`linear-gradient(90deg,${C.green},rgba(76,175,122,0.25))`, borderRadius:1 }} />\n      {mkParticle(n2x+NW, 2.18, 0.58)}\n      {mkParticle(n2x+NW, 2.58, 0.50)}\n      {mkNode(n3x, a(0,1,2.02,2.44,Easing.easeOutBack), a(22,0,2.02,2.44), false, C.green, 'Trader Trust', 'Brand Credibility', C.greenInk, C.green,\n        <svg width=\"30\" height=\"30\" viewBox=\"0 0 30 30\" fill=\"none\"><circle cx=\"15\" cy=\"15\" r=\"13\" fill=\"rgba(76,175,122,0.12)\"/><path d=\"M8 15l5 5 9-9\" stroke={C.green} strokeWidth=\"2.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\"/></svg>\n      )}\n      <div style={{ position:'absolute', bottom:42, left:0, right:0, textAlign:'center', opacity:a(0,1,2.48,2.95), transform:`translateY(${a(12,0,2.48,2.95)}px)`, fontFamily:f, fontSize:24, fontWeight:600, color:C.ink2, letterSpacing:'-0.02em' }}>Your brand earns trust through trusted association</div>\n    </>\n  );\n}\n\nfunction Scene4() {\n  const t = useTime(), lt = t - 12;\n  const a = (fr, to, s, en, ease) => animate({ from:fr, to, start:s, end:en, ease: ease||Easing.easeOutCubic })(lt);\n  const stats = [\n    { num:'50K+', label:'Active Traders',       color:C.green,  d:0.88 },\n    { num:'3×',   label:'Higher Brand Recall',   color:C.yellow, d:1.08 },\n    { num:'94%',  label:'Reader Retention Rate', color:C.red,    d:1.28 },\n  ];\n  return (\n    <>\n      <div style={{ position:'absolute', left:80, top:0, bottom:0, width:580, display:'flex', flexDirection:'column', justifyContent:'center' }}>\n        <div style={{ opacity:a(0,1,0.18,0.52), fontFamily:f, fontSize:15, fontWeight:700, letterSpacing:'0.14em', textTransform:'uppercase', color:C.green, marginBottom:12 }}>Advertise on Maxgazine</div>\n        <div style={{ opacity:a(0,1,0.32,0.78), transform:`translateY(${a(20,0,0.32,0.78)}px)`, fontFamily:f, fontSize:62, fontWeight:900, letterSpacing:'-0.03em', color:C.ink, lineHeight:1.02, marginBottom:16, whiteSpace:'pre-wrap' }}>{'Reach traders at the\\nmoment of trust.'}</div>\n        <div style={{ opacity:a(0,1,0.78,1.18), fontFamily:f, fontSize:19, fontWeight:500, color:C.muted, letterSpacing:'-0.01em', lineHeight:1.55, marginBottom:28, whiteSpace:'pre-wrap' }}>{'Your brand earns credibility through association\\nwith the source traders rely on every day.'}</div>\n        <div style={{ opacity:a(0,1,1.28,1.65), transform:`translateY(${a(16,0,1.28,1.65,Easing.easeOutBack)}px)` }}>\n          <div style={{ display:'inline-block', background:C.green, color:C.greenInk, padding:'14px 32px', borderRadius:'999px', fontFamily:f, fontSize:17, fontWeight:700, letterSpacing:'-0.01em', boxShadow:'0 4px 22px rgba(76,175,122,0.32)' }}>Start Advertising →</div>\n        </div>\n      </div>\n      <div style={{ position:'absolute', right:72, top:0, bottom:0, width:380, display:'flex', flexDirection:'column', justifyContent:'center', gap:12 }}>\n        {stats.map(({ num, label, color, d }) => (\n          <div key={label} style={{ opacity:a(0,1,d,d+0.34), transform:`translateX(${a(42,0,d,d+0.34)}px)`, background:C.card, borderRadius:14, padding:'18px 22px', boxShadow:'0 1px 3px rgba(20,32,31,0.06),0 4px 14px rgba(20,32,31,0.05)', display:'flex', alignItems:'center', gap:16 }}>\n            <div style={{ fontFamily:f, fontSize:48, fontWeight:900, letterSpacing:'-0.04em', color, lineHeight:1, minWidth:84 }}>{num}</div>\n            <div style={{ fontFamily:f, fontSize:17, fontWeight:600, color:C.ink, letterSpacing:'-0.01em', lineHeight:1.3 }}>{label}</div>\n          </div>\n        ))}\n      </div>\n    </>\n  );\n}\n\nfunction App() {\n  return (\n    <Stage width={1200} height={400} duration={16} background={C.bg} loop autoplay>\n      <GridBg />\n      <SceneWrap idx={0}><Scene1 /></SceneWrap>\n      <SceneWrap idx={1}><Scene2 /></SceneWrap>\n      <SceneWrap idx={2}><Scene3 /></SceneWrap>\n      <SceneWrap idx={3}><Scene4 /></SceneWrap>\n    </Stage>\n  );\n}\n\nReactDOM.createRoot(document.getElementById('root')).render(<App />);\n</script>\n</body>\n</html>\n"
    },
